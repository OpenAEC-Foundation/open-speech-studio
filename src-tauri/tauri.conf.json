{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Open Speech Studio",
  "version": "0.5.0",
  "identifier": "org.openaec.speech-studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3025",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Open Speech Studio",
        "width": 900,
        "height": 640,
        "resizable": true,
        "maximizable": false,
        "fullscreen": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "visible": false,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../bin/*",
      "../models/ggml-small.bin"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": true,
        "languages": ["English", "Dutch"],
        "installerHooks": "nsis-hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libasound2-dev", "libxdo-dev"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {}
}
